@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="user-info">User @context.User.Identity?.Name (@context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</span>
                    <form method="post" action="/logout">
                        <button type="submit" class="btn-logout">Logout</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="/login">Login</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">x</a>
</div>

<style>
    .top-row {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 16px;
        padding: 10px 0;
        height: 50px;
    }

    .user-info {
        font-weight: 500;
    }

    .btn-logout {
        padding: 6px 16px;
        background: #f44336;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
    }
</style>
