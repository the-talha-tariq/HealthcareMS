@page "/chat"
@using HealthcareMS.Web.Models
@using HealthcareMS.Web.Services
@inject AIAssistantApiService AIAssistantApi
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>AI Assistant - HealthcareMS</PageTitle>

<div class="chat-container">
    <div class="chat-header">
        <h2>🤖 HealthcareMS AI Assistant</h2>
        <small>Ask about appointments, patients, or general healthcare questions</small>
    </div>

    <div class="chat-messages" id="chatMessages">
        @if (!messages.Any())
        {
            <div class="welcome-message">
                <p>👋 Hello! I am your HealthcareMS AI Assistant.</p>
                <p>You can ask me things like:</p>
                <ul>
                    <li>"What are the upcoming appointments for patient 1?"</li>
                    <li>"Summarize patient 1's profile"</li>
                    <li>"How many active patients are in the system?"</li>
                    <li>"What is the difference between Type 1 and Type 2 diabetes?"</li>
                </ul>
            </div>
        }

        @foreach (var msg in messages)
        {
            <div class="message @(msg.Role == "user" ? "user-message" : "assistant-message")">
                <div class="message-bubble">
                    <span class="message-role">
                        @(msg.Role == "user" ? "You" : "AI Assistant")
                    </span>
                    <p>@msg.Content</p>
                </div>
            </div>
        }

        @if (isStreaming)
        {
            <div class="message assistant-message">
                <div class="message-bubble">
                    <span class="message-role">AI Assistant</span>
                    <p>@streamingContent<span class="cursor">▋</span></p>
                </div>
            </div>
        }
    </div>

    <div class="chat-input-area">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-danger">@errorMessage</div>
        }

        <div class="patient-selector">
            <label>Patient Context (optional):</label>
            <input type="number" @bind="patientId" placeholder="Patient ID"
                   class="patient-id-input" min="1" />
        </div>

        <div class="input-row">
            <textarea @bind="userInput"
                      @onkeydown="HandleKeyDown"
                      placeholder="Ask me anything about your healthcare..."
                      class="chat-input"
                      rows="2"
                      disabled="@isStreaming"></textarea>
            <button @onclick="SendMessage"
                    disabled="@(isStreaming || string.IsNullOrEmpty(userInput))"
                    class="send-button">
                @(isStreaming ? "..." : "Send")
            </button>
        </div>
    </div>
</div>

<style>
    .chat-container {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 120px);
        max-width: 900px;
        margin: 0 auto;
    }
    .chat-header {
        padding: 16px;
        background: #2196F3;
        color: white;
        border-radius: 12px 12px 0 0;
        text-align: center;
    }
    .chat-header h2 { margin: 0; }
    .chat-header small { opacity: 0.9; }
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        background: #f5f5f5;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .welcome-message {
        background: white;
        padding: 20px;
        border-radius: 12px;
        border-left: 4px solid #2196F3;
    }
    .welcome-message ul { margin: 8px 0 0 20px; }
    .welcome-message li { margin: 4px 0; color: #555; }
    .message { display: flex; }
    .user-message { justify-content: flex-end; }
    .assistant-message { justify-content: flex-start; }
    .message-bubble {
        max-width: 70%;
        padding: 12px 16px;
        border-radius: 12px;
        background: white;
        box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    }
    .user-message .message-bubble {
        background: #2196F3;
        color: white;
    }
    .message-role {
        font-size: 11px;
        font-weight: bold;
        opacity: 0.7;
        display: block;
        margin-bottom: 4px;
    }
    .message-bubble p { margin: 0; white-space: pre-wrap; }
    .cursor {
        animation: blink 1s infinite;
    }
    @@keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }
    .chat-input-area {
        padding: 16px;
        background: white;
        border-top: 1px solid #ddd;
        border-radius: 0 0 12px 12px;
    }
    .patient-selector {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
        font-size: 13px;
        color: #666;
    }
    .patient-id-input {
        width: 100px;
        padding: 4px 8px;
        border: 1px solid #ddd;
        border-radius: 4px;
    }
    .input-row {
        display: flex;
        gap: 8px;
    }
    .chat-input {
        flex: 1;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 8px;
        resize: none;
        font-size: 14px;
    }
    .send-button {
        padding: 10px 24px;
        background: #2196F3;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 14px;
        align-self: flex-end;
    }
    .send-button:disabled { background: #ccc; cursor: not-allowed; }
    .alert-danger {
        background: #ffebee;
        color: #c62828;
        padding: 8px 12px;
        border-radius: 6px;
        margin-bottom: 8px;
        font-size: 13px;
    }
</style>

@code {
    private List<(string Role, string Content)> messages = new();
    private string userInput = string.Empty;
    private string streamingContent = string.Empty;
    private bool isStreaming = false;
    private string? errorMessage;
    private int? patientId;
    private string sessionId = Guid.NewGuid().ToString();

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !isStreaming)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrEmpty(userInput) || isStreaming) return;

        var message = userInput.Trim();
        userInput = string.Empty;
        errorMessage = null;

        // Add user message to UI immediately
        messages.Add(("user", message));
        isStreaming = true;
        streamingContent = string.Empty;
        StateHasChanged();

        try
        {
            var (response, error) = await AIAssistantApi.ChatAsync(
                message, sessionId, patientId);

            if (response == null)
            {
                errorMessage = error ?? "Failed to get response from AI Assistant.";
                return;
            }

            messages.Add(("assistant", response.Reply));
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isStreaming = false;
            streamingContent = string.Empty;
            StateHasChanged();
        }
    }

}
