@page "/appointments"
@page "/appointments/patient/{PatientId:int}"
@using HealthcareMS.Web.Models
@using HealthcareMS.Web.Services
@inject AppointmentApiService AppointmentApi
@inject NavigationManager Navigation
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Appointments - HealthcareMS</PageTitle>

<div class="page-header">
    <h2>@(PatientId.HasValue ? $"Appointments for Patient #{PatientId}" : "All Appointments")</h2>
    <button class="btn btn-primary" @onclick="GoToCreate">+ Book Appointment</button>
</div>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (appointments.Count == 0)
{
    <p>No appointments found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Patient</th>
                <th>Doctor</th>
                <th>Department</th>
                <th>Date</th>
                <th>Time Slot</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var appt in appointments)
            {
                <tr>
                    <td>@appt.Id</td>
                    <td>@appt.PatientName</td>
                    <td>@appt.DoctorName</td>
                    <td>@appt.Department</td>
                    <td>@appt.AppointmentDate.ToString("dd MMM yyyy")</td>
                    <td>@appt.TimeSlot</td>
                    <td>
                        <span class="badge badge-@appt.Status.ToLower()">@appt.Status</span>
                    </td>
                    <td>
                        @if (appt.Status != "Cancelled")
                        {
                            <button class="btn btn-sm btn-danger" @onclick="() => CancelAppointment(appt.Id)">Cancel</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
    }

    .table th, .table td {
        padding: 12px;
        border: 1px solid #ddd;
        text-align: left;
    }

    .table th {
        background: #f5f5f5;
    }

    .btn {
        padding: 8px 16px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
    }

    .btn-primary { background: #2196F3; color: white; }
    .btn-sm { padding: 4px 10px; font-size: 13px; }
    .btn-danger { background: #f44336; color: white; }

    .badge {
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 12px;
        color: white;
    }

    .badge-scheduled { background: #2196F3; }
    .badge-confirmed { background: #4caf50; }
    .badge-cancelled { background: #f44336; }
    .badge-completed { background: #9e9e9e; }
</style>

@code {
    [Parameter]
    public int? PatientId { get; set; }

    private List<AppointmentModel> appointments = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAppointments();
    }

    private async Task LoadAppointments()
    {
        isLoading = true;

        appointments = PatientId.HasValue
            ? await AppointmentApi.GetByPatientIdAsync(PatientId.Value)
            : await AppointmentApi.GetAllAsync();

        isLoading = false;
    }

    private void GoToCreate()
    {
        var url = PatientId.HasValue
            ? $"/appointments/create?patientId={PatientId}"
            : "/appointments/create";
        Navigation.NavigateTo(url);
    }

    private async Task CancelAppointment(int id)
    {
        var success = await AppointmentApi.CancelAsync(id);
        if (success)
        {
            await LoadAppointments();
        }
    }
}
