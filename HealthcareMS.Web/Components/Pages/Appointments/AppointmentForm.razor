@page "/appointments/create"
@using HealthcareMS.Web.Models
@using HealthcareMS.Web.Services
@using Microsoft.AspNetCore.WebUtilities
@inject AppointmentApiService AppointmentApi
@inject PatientApiService PatientApi
@inject NavigationManager Navigation
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Book Appointment - HealthcareMS</PageTitle>

<h2>Book New Appointment</h2>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<EditForm Model="@model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <div class="form-group">
        <label>Patient</label>
        <InputSelect @bind-Value="model.PatientId" class="form-control">
            <option value="0">-- Select Patient --</option>
            @foreach (var patient in patients)
            {
                <option value="@patient.Id">@patient.FullName (@patient.Email)</option>
            }
        </InputSelect>
    </div>

    <div class="form-row">
        <div class="form-group">
            <label>Doctor Name</label>
            <InputText @bind-Value="model.DoctorName" class="form-control" placeholder="Dr. Ahmed Ali" />
        </div>
        <div class="form-group">
            <label>Department</label>
            <InputText @bind-Value="model.Department" class="form-control" placeholder="Cardiology" />
        </div>
    </div>

    <div class="form-row">
        <div class="form-group">
            <label>Appointment Date</label>
            <InputDate @bind-Value="model.AppointmentDate" class="form-control" />
        </div>
        <div class="form-group">
            <label>Time Slot</label>
            <InputText @bind-Value="model.TimeSlot" class="form-control" placeholder="10:00 AM - 10:30 AM" />
        </div>
    </div>

    <div class="form-group">
        <label>Notes</label>
        <InputTextArea @bind-Value="model.Notes" class="form-control" rows="3" />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@isLoading">
        @(isLoading ? "Booking..." : "Book Appointment")
    </button>
    <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
</EditForm>

<style>
    .form-row {
        display: flex;
        gap: 16px;
        margin-bottom: 16px;
    }

    .form-group {
        flex: 1;
        margin-bottom: 16px;
    }

    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-weight: 500;
    }

    .form-control {
        width: 100%;
        padding: 8px;
        border: 1px solid #ddd;
        border-radius: 6px;
    }

    .btn {
        padding: 10px 24px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        margin-right: 8px;
    }

    .btn-primary { background: #2196F3; color: white; }
    .btn-secondary { background: #9e9e9e; color: white; }

    .alert-danger {
        background: #ffebee;
        color: #c62828;
        padding: 10px;
        border-radius: 6px;
        margin-bottom: 16px;
    }
</style>

@code {
    [SupplyParameterFromQuery]
    public int? PatientId { get; set; }

    private CreateAppointmentModel model = new();
    private List<PatientModel> patients = new();
    private string? errorMessage;
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        patients = await PatientApi.GetAllAsync();

        if (PatientId.HasValue)
        {
            model.PatientId = PatientId.Value;
        }
    }

    private async Task HandleSubmit()
    {
        if (model.PatientId == 0)
        {
            errorMessage = "Please select a patient.";
            return;
        }

        isLoading = true;
        errorMessage = null;

        var (success, error) = await AppointmentApi.CreateAsync(model);

        isLoading = false;

        if (success)
        {
            Navigation.NavigateTo("/appointments");
        }
        else
        {
            errorMessage = error ?? "Failed to book appointment.";
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/appointments");
    }
}
