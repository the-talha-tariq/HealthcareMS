@page "/patients/create"
@using HealthcareMS.Web.Models
@using HealthcareMS.Web.Services
@inject PatientApiService PatientApi
@inject NavigationManager Navigation
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>New Patient - HealthcareMS</PageTitle>

<h2>Register New Patient</h2>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<EditForm Model="@model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <div class="form-row">
        <div class="form-group">
            <label>First Name</label>
            <InputText @bind-Value="model.FirstName" class="form-control" />
        </div>
        <div class="form-group">
            <label>Last Name</label>
            <InputText @bind-Value="model.LastName" class="form-control" />
        </div>
    </div>

    <div class="form-row">
        <div class="form-group">
            <label>Email</label>
            <InputText @bind-Value="model.Email" class="form-control" />
        </div>
        <div class="form-group">
            <label>Phone</label>
            <InputText @bind-Value="model.Phone" class="form-control" />
        </div>
    </div>

    <div class="form-row">
        <div class="form-group">
            <label>Date of Birth</label>
            <InputDate @bind-Value="model.DateOfBirth" class="form-control" />
        </div>
        <div class="form-group">
            <label>Gender</label>
            <InputSelect @bind-Value="model.Gender" class="form-control">
                <option value="Male">Male</option>
                <option value="Female">Female</option>
                <option value="Other">Other</option>
            </InputSelect>
        </div>
    </div>

    <div class="form-row">
        <div class="form-group">
            <label>Blood Group</label>
            <InputSelect @bind-Value="model.BloodGroup" class="form-control">
                <option value="A+">A+</option>
                <option value="A-">A-</option>
                <option value="B+">B+</option>
                <option value="B-">B-</option>
                <option value="O+">O+</option>
                <option value="O-">O-</option>
                <option value="AB+">AB+</option>
                <option value="AB-">AB-</option>
            </InputSelect>
        </div>
        <div class="form-group">
            <label>Address</label>
            <InputText @bind-Value="model.Address" class="form-control" />
        </div>
    </div>

    <button type="submit" class="btn btn-primary" disabled="@isLoading">
        @(isLoading ? "Saving..." : "Register Patient")
    </button>
    <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
</EditForm>

<style>
    .form-row {
        display: flex;
        gap: 16px;
        margin-bottom: 16px;
    }

    .form-group {
        flex: 1;
    }

    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-weight: 500;
    }

    .form-control {
        width: 100%;
        padding: 8px;
        border: 1px solid #ddd;
        border-radius: 6px;
    }

    .btn {
        padding: 10px 24px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        margin-right: 8px;
    }

    .btn-primary { background: #2196F3; color: white; }
    .btn-secondary { background: #9e9e9e; color: white; }

    .alert-danger {
        background: #ffebee;
        color: #c62828;
        padding: 10px;
        border-radius: 6px;
        margin-bottom: 16px;
    }
</style>

@code {
    private CreatePatientModel model = new();
    private string? errorMessage;
    private bool isLoading = false;

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = null;

        var (success, error) = await PatientApi.CreateAsync(model);

        isLoading = false;

        if (success)
        {
            Navigation.NavigateTo("/patients");
        }
        else
        {
            errorMessage = error ?? "Failed to create patient.";
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/patients");
    }
}
